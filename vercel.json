{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|google.*\\.html|manifest\\.webmanifest|sw\\.js|favicon.*).*)",
      "destination": "/index.html"
    }
  ]
}
